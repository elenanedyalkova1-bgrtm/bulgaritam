---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadProducts } from "../lib/products";

const products = await loadProducts();

/** ✅ 1) EXACT map: Sheet category name (BG) -> internal key */
const CATEGORY_MAP = {
  "Подаръци": "gifts",
  "Облекло": "clothing",
  "Дом и интериор": "home",
  "За дома": "home",
  "За деца": "kids",
  "Здраве и грижа": "health",
  "Козметика": "cosmetics",
  "Аксесоари": "accessories",
  "Домашни любимци": "pets",
  "Забавление": "fun",
  "Бижута": "jewelry",
};

/** ✅ 2) Pills (UI) — filter by key, show Bulgarian labels */
const categories = [
  { key: "gifts", label: "🎁 Подаръци" },
  { key: "clothing", label: "👕 Облекло" },
  { key: "home", label: "🏠 Дом и интериор" },
  { key: "kids", label: "👶 За деца" },
  { key: "health", label: "🌿 Здраве и грижа" },
  { key: "cosmetics", label: "💄 Козметика" },
  { key: "accessories", label: "👜 Аксесоари" },
  { key: "pets", label: "🐾 Домашни любимци" },
  { key: "fun", label: "🎲 Забавление" },
  { key: "jewelry", label: "💍 Бижута" },
];

const toKeyFromSheetCategory = (categoryName) => {
  const name = String(categoryName || "").trim();
  return CATEGORY_MAP[name] || "";
};

/** ✅ 3) Build brand map using ONLY product.category (sheet) -> key */
const brandsMap = new Map();

for (const p of products) {
  if (!p.brand_slug) continue;

  const key = toKeyFromSheetCategory(p.category);
  if (!key) continue; // category not mapped yet

  const entry = brandsMap.get(p.brand_slug) || {
    name: p.brand_name || p.brand_slug,
    slug: p.brand_slug,
    keys: new Set(),
    count: 0,
  };

  entry.keys.add(key);
  entry.count += 1;

  brandsMap.set(p.brand_slug, entry);
}

const brands = Array.from(brandsMap.values()).map((b) => ({
  ...b,
  keys: Array.from(b.keys),
}));

// SEO
const title = "Български брандове – каталог на родни марки | Българитъм";
const description =
  "Открий подбрани български брандове и родни производители по категории – дом и интериор, козметика, облекло, подаръци и още.";
const canonical = "https://bulgaritam.bg/bulgarski-brandove/";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main class="container">
    <!-- HERO -->
    <header class="page-head">
      <h1>Български брандове</h1>
      <p class="lead">
        Подбрана селекция от български брандове и родни производители. Открий качествени
        продукти, създадени в България.
      </p>
    </header>

    <!-- CATEGORIES -->
    <section class="section">
      <h2 class="section-title">Категории български брандове</h2>

      <div class="pills" id="brand-filters" aria-label="Филтри по категория">
        <button class="pill is-active" type="button" data-filter="all">Всички</button>

        {categories.map((c) => (
          <button class="pill" type="button" data-filter={c.key}>
            {c.label}
          </button>
        ))}
      </div>
    </section>

    <!-- BRANDS -->
    <section class="section">
      <h2 class="section-title">Подбрани български брандове</h2>

      <ul class="brand-grid" id="brand-grid">
        {brands.map((b) => (
          <li class="brand-card" data-brand data-keys={b.keys.join(",")}>
            <a class="brand-link" href={`/brand/${b.slug}`}>
              <div class="brand-name">{b.name}</div>
              <div class="brand-meta">
                {b.count} продукта
                {b.keys.length ? ` • ${b.keys.length} категории` : ""}
              </div>
            </a>
          </li>
        ))}
      </ul>

      <!-- Optional empty state -->
      <p id="brand-empty" class="empty" hidden>
        Няма брандове в тази категория засега.
      </p>
    </section>

    <!-- EDITORIAL -->
    <section class="editorial">
      <h2 class="section-title">Защо да избереш български брандове</h2>
      <p class="editorial-p">
        Избирайки български брандове, подкрепяш малки бизнеси, родни производители и
        устойчиви практики. Все повече български марки предлагат качество, сравнимо с
        международните брандове.
      </p>
    </section>
  </main>

  <style>
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 32px 16px 64px;
    }

    .page-head {
      text-align: center;
      padding: 14px 0 6px;
    }

    /* If you already have global page h1 rules, this will still look fine */
    .page-head h1 {
      margin: 0 0 10px;
      font-size: clamp(34px, 4.6vw, 54px);
      letter-spacing: -0.02em;
      line-height: 1.06;
    }

    .lead {
      margin: 0 auto;
      max-width: 760px;
      font-size: 18px;
      line-height: 1.75;
      opacity: 0.9;
    }

    .section {
      margin-top: 38px;
    }

    .section-title {
      margin: 0 0 16px;
      font-size: 22px;
      letter-spacing: -0.01em;
      text-align: left;
      opacity: 0.9;
    }

    /* Pills */
    .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      align-items: center;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.72);
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06);
      transition: transform 0.08s ease, background 0.12s ease;
    }

    .pill:hover {
      background: rgba(255, 255, 255, 0.86);
    }

    .pill:active {
      transform: scale(0.99);
    }

    .pill.is-active {
      border-color: rgba(95, 127, 107, 0.45);
      background: rgba(95, 127, 107, 0.12);
    }

    /* Brands grid */
    .brand-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
    }

    .brand-card {
      border: 1px solid var(--border);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06);
    }

    .brand-link {
      display: block;
      padding: 16px;
      text-decoration: none;
      color: inherit;
    }

    .brand-name {
      font-weight: 900;
    }

    .brand-meta {
      margin-top: 6px;
      font-size: 14px;
      opacity: 0.7;
    }

    .empty {
      margin-top: 14px;
      text-align: center;
      opacity: 0.75;
    }

    .editorial {
      max-width: 760px;
      margin-top: 46px;
      opacity: 0.86;
    }

    .editorial-p {
      margin: 10px 0 0;
      line-height: 1.7;
    }

    @media (max-width: 520px) {
      .page-head h1 {
        font-size: clamp(30px, 8.5vw, 44px);
      }
    }
  </style>

  <script is:inline>
    const filters = document.getElementById("brand-filters");
    const cards = Array.from(document.querySelectorAll("[data-brand]"));
    const empty = document.getElementById("brand-empty");

    const getKeys = (el) =>
      (el.getAttribute("data-keys") || "")
        .split(",")
        .map((k) => k.trim())
        .filter(Boolean);

    const setActive = (btn) => {
      filters.querySelectorAll(".pill").forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
    };

    const applyFilter = (key) => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const keys = getKeys(card);
        const show = key === "all" ? true : keys.includes(key);
        card.style.display = show ? "" : "none";
        if (show) visibleCount += 1;
      });

      if (empty) {
        if (visibleCount === 0) empty.removeAttribute("hidden");
        else empty.setAttribute("hidden", "");
      }
    };

    filters.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-filter]");
      if (!btn) return;

      const key = btn.getAttribute("data-filter") || "all";
      setActive(btn);
      applyFilter(key);
    });

    applyFilter("all");
  </script>
</BaseLayout>
