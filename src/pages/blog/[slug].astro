---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Render markdown to component
const { Content } = await post.render();

const pageTitle = `${post.data.title} — Българитъм`;
const pageDescription = post.data.description;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="post">
    <article class="post__article">
      <header class="post__header">
        <p class="post__kicker">
          <a href="/blog/">Препоръчано от Българитъм</a>
        </p>

        <h1 class="post__title">{post.data.title}</h1>

        {post.data.pubDate ? (
          <time class="post__date" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("bg-BG", {
              year: "numeric",
              month: "long",
              day: "2-digit",
            })}
          </time>
        ) : null}

        <p class="post__intro">{post.data.description}</p>
      </header>

      <section class="post__content">
        <Content />
      </section>
    </article>
  </main>

  <style>
    .post {
      max-width: 980px;
      margin: 0 auto;
      padding: 28px 16px 56px;
    }

    .post__article {
      max-width: 760px;
      margin: 0 auto;
    }

    .post__kicker {
      margin: 0 0 10px;
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 13px;
      opacity: 0.8;
    }

    .post__kicker a {
      color: inherit;
      text-decoration: none;
    }
    .post__kicker a:hover { text-decoration: underline; }

    .post__title {
      margin: 0 0 10px;
      font-family: "Fraunces", ui-serif, Georgia, serif;
      font-size: clamp(32px, 4vw, 46px);
      line-height: 1.1;
    }

    .post__date {
      display: inline-block;
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 13px;
      opacity: 0.75;
      margin-bottom: 12px;
    }

    .post__intro {
      margin: 0;
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      opacity: 0.92;
    }

    .post__content {
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid rgba(0,0,0,0.10);
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      line-height: 1.8;
      font-size: 16px;
    }

    /* Editorial typography for markdown */
    .post__content :global(h2) {
      margin: 22px 0 10px;
      font-family: "Fraunces", ui-serif, Georgia, serif;
      font-size: 24px;
      line-height: 1.2;
    }

    .post__content :global(h3) {
      margin: 18px 0 8px;
      font-family: "Fraunces", ui-serif, Georgia, serif;
      font-size: 20px;
      line-height: 1.25;
    }

    .post__content :global(p) { margin: 0 0 14px; }

    .post__content :global(ul),
    .post__content :global(ol) {
      margin: 0 0 14px;
      padding-left: 18px;
    }

    .post__content :global(a) {
      color: inherit;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
  </style>
</BaseLayout>
