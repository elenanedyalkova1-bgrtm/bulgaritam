---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => {
    const aTime = a.data.pubDate ? a.data.pubDate.getTime() : 0;
    const bTime = b.data.pubDate ? b.data.pubDate.getTime() : 0;
    return bTime - aTime;
  });

const pageTitle = "Препоръчано от Българитъм";
const pageDescription =
  "Кураторски текстове за български брандове, продукти, истории и идеи за подаръци — спокойно, подбрано и полезно.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="blog">
    <header class="blog__header">
      <h1 class="blog__title">{pageTitle}</h1>
      <p class="blog__intro">
        Българитъм не е маркетплейс. Ние курираме — за да откриваш български брандове
        и находки без шум: продуктови истории, идеи за подаръци и внимателно подбрани категории.
      </p>
    </header>

    <section class="blog__grid" aria-label="Статии">
      {posts.length === 0 ? (
        <div class="blog__empty">
          <p>Още подготвяме първите препоръки. Ела пак скоро ✨</p>
        </div>
      ) : (
        posts.map((post) => (
          <article class="card">
            <div class="card__meta">
              {post.data.pubDate ? (
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("bg-BG", {
                    year: "numeric",
                    month: "long",
                    day: "2-digit",
                  })}
                </time>
              ) : null}
            </div>

            <h2 class="card__title">
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h2>

            <p class="card__excerpt">{post.data.description}</p>

            <a class="card__link" href={`/blog/${post.slug}/`}>
              Прочети →
            </a>
          </article>
        ))
      )}
    </section>
  </main>

  <style>
    .blog {
      max-width: 980px;
      margin: 0 auto;
      padding: 28px 16px 56px;
    }

    .blog__header {
      max-width: 720px;
      margin: 0 auto 28px;
      text-align: center;
    }

    .blog__title {
      font-family: "Fraunces", ui-serif, Georgia, serif;
      font-size: clamp(32px, 4vw, 44px);
      line-height: 1.1;
      margin: 0 0 12px;
    }

    .blog__intro {
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.65;
      margin: 0;
      opacity: 0.9;
    }

    .blog__grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 14px;
      margin-top: 26px;
    }

    .card {
      grid-column: span 12;
      padding: 18px 18px 16px;
      border: 1px solid rgba(0,0,0,0.10);
      border-radius: 16px;
      background: rgba(255,255,255,0.55);
      backdrop-filter: blur(6px);
    }

    @media (min-width: 720px) {
      .card { grid-column: span 6; }
    }

    .card__meta {
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 13px;
      opacity: 0.75;
      margin-bottom: 10px;
    }

    .card__title {
      margin: 0 0 10px;
      font-family: "Fraunces", ui-serif, Georgia, serif;
      font-size: 22px;
      line-height: 1.2;
    }

    .card__title a {
      color: inherit;
      text-decoration: none;
    }

    .card__title a:hover {
      text-decoration: underline;
    }

    .card__excerpt {
      margin: 0 0 14px;
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      line-height: 1.6;
      opacity: 0.9;
    }

    .card__link {
      font-family: "Inter", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      text-decoration: none;
      opacity: 0.9;
    }

    .card__link:hover {
      text-decoration: underline;
    }

    .blog__empty {
      grid-column: span 12;
      text-align: center;
      padding: 22px;
      border: 1px dashed rgba(0,0,0,0.18);
      border-radius: 16px;
      opacity: 0.85;
    }
  </style>
</BaseLayout>
